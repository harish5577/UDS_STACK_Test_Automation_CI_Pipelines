      break;

    case 15:
      Send_Diag_Request(0x04, 0x19, 0x08, 0x80, 0x29, IDLE, IDLE, IDLE);
      testWaitForTimeout(900);
      if (SID_19 == 9)
      { testStepPass("PASS"); testReportAddWindowCapture("Trace","",""); }
      else
      { testStepFail("FAIL"); testReportAddWindowCapture("Trace","",""); }
      ReadDTCInformation();
      break;

    case 16:
      Send_Diag_Request(0x04, 0x09, 0x08, 0x40, 0x21, IDLE, IDLE, IDLE);
      testWaitForTimeout(900);
      testStep("", "NRC 11 - serviceNotSupported (SID=0x09)");
      if (SID_19 == 16)
      { testStepPass("PASS"); testReportAddWindowCapture("Trace","",""); }
      else
      { testStepFail("FAIL"); testReportAddWindowCapture("Trace","",""); }
      ReadDTCInformation();
      break;

    case 17:
      Send_Diag_Request(0x04, 0x09, 0x08, 0x80, 0x21, IDLE, IDLE, IDLE);
      testWaitForTimeout(900);
      if (SID_19 == 16)
      { testStepPass("PASS"); testReportAddWindowCapture("Trace","",""); }
      else
      { testStepFail("FAIL"); testReportAddWindowCapture("Trace","",""); }
      ReadDTCInformation();
      break;

    case 18:
      Send_Diag_Request(0x04, 0x19, 0x00, 0x40, 0x21, IDLE, IDLE, IDLE);
      testWaitForTimeout(900);
      testStep("", "NRC 12 - subFunctionNotSupported (sub=0x00)");
      if (SID_19 == 13)
      { testStepPass("PASS"); testReportAddWindowCapture("Trace","",""); }
      else
      { testStepFail("FAIL"); testReportAddWindowCapture("Trace","",""); }
      ReadDTCInformation();
      break;

    case 19:
      Send_Diag_Request(0x04, 0x19, 0xFF, 0x80, 0x21, IDLE, IDLE, IDLE);
      testWaitForTimeout(900);
      if (SID_19 == 13)
      { testStepPass("PASS"); testReportAddWindowCapture("Trace","",""); }
      else
      { testStepFail("FAIL"); testReportAddWindowCapture("Trace","",""); }
      ReadDTCInformation();
      break;

    /* case 20 â€” sub 0x09 reportDTCExtDataRecordByRecordNumber */
    case 20:
      if (DtcIndex == 0)
      {
        testStep("", "12.3.2.2 sub 0x09 - reportDTCExtDataRecordByRecordNumber (44 DTCs)");
        Phase_pass = 0; Phase_fail = 0;
      }
      if (DtcIndex < 44)
      {
        Send_Diag_Request(0x05, 0x19, 0x09, DTC_LIST[DtcIndex][0], DTC_LIST[DtcIndex][1], DTC_LIST[DtcIndex][2], IDLE, IDLE);
        testWaitForTimeout(900);
        snprintf(Buffer, elcount(Buffer), "19 09 %02X %02X %02X [DTC %d / 44]", DTC_LIST[DtcIndex][0], DTC_LIST[DtcIndex][1], DTC_LIST[DtcIndex][2], DtcIndex + 1);
        testStep("", Buffer);
        if (SID_19 == 10) { testStepPass("PASS"); testReportAddWindowCapture("Trace","",""); Phase_pass++; }
        else             { testStepFail("FAIL"); testReportAddWindowCapture("Trace","",""); Phase_fail++; }
        DtcIndex++; READ_DTC--; ReadDTCInformation();
      }
      else
      {
        snprintf(Buffer, elcount(Buffer), "sub 0x09 complete - %d PASS / %d FAIL", Phase_pass, Phase_fail);
        testStep("Summary sub 0x09", Buffer);
        DtcIndex = 0; ReadDTCInformation();
      }
      break;

    /* case 21 â€” sub 0x04 RN=0x02 */
    case 21:
      if (DtcIndex == 0) { testStep("", "sub 0x04 RN=0x02 (44 DTCs)"); Phase_pass = 0; Phase_fail = 0; }
      if (DtcIndex < 44)
      {
        Send_Diag_Request(0x06, 0x19, 0x04, DTC_LIST[DtcIndex][0], DTC_LIST[DtcIndex][1], DTC_LIST[DtcIndex][2], 0x02, IDLE);
        testWaitForTimeout(900);
        if (SID_19 == 7) { testStepPass("PASS"); testReportAddWindowCapture("Trace","",""); Phase_pass++; }
        else             { testStepFail("FAIL"); testReportAddWindowCapture("Trace","",""); Phase_fail++; }
        DtcIndex++; READ_DTC--; ReadDTCInformation();
      }
      else
      {
        snprintf(Buffer, elcount(Buffer), "sub 0x04 RN=02 complete - %d PASS / %d FAIL", Phase_pass, Phase_fail);
        testStep("Summary sub 0x04 RN=02", Buffer);
        DtcIndex = 0; ReadDTCInformation();
      }
      break;

    /* case 22 â€” sub 0x04 RN=0x01 */
    case 22:
      if (DtcIndex == 0) { testStep("", "sub 0x04 RN=0x01 (44 DTCs)"); Phase_pass = 0; Phase_fail = 0; }
      if (DtcIndex < 44)
      {
        Send_Diag_Request(0x06, 0x19, 0x04, DTC_LIST[DtcIndex][0], DTC_LIST[DtcIndex][1], DTC_LIST[DtcIndex][2], 0x01, IDLE);
        testWaitForTimeout(900);
        if (SID_19 == 7) { testStepPass("PASS"); testReportAddWindowCapture("Trace","",""); Phase_pass++; }
        else             { testStepFail("FAIL"); testReportAddWindowCapture("Trace","",""); Phase_fail++; }
        DtcIndex++; READ_DTC--; ReadDTCInformation();
      }
      else
      {
        snprintf(Buffer, elcount(Buffer), "sub 0x04 RN=01 complete - %d PASS / %d FAIL", Phase_pass, Phase_fail);
        testStep("Summary sub 0x04 RN=01", Buffer);
        DtcIndex = 0; ReadDTCInformation();
      }
      break;

    /* case 23 â€” sub 0x06 ExtRN=0x00 */
    case 23:
      if (DtcIndex == 0) { testStep("", "sub 0x06 ExtRN=0x00 (44 DTCs)"); Phase_pass = 0; Phase_fail = 0; }
      if (DtcIndex < 44)
      {
        Send_Diag_Request(0x06, 0x19, 0x06, DTC_LIST[DtcIndex][0], DTC_LIST[DtcIndex][1], DTC_LIST[DtcIndex][2], 0x00, IDLE);
        testWaitForTimeout(900);
        if (SID_19 == 8) { testStepPass("PASS"); testReportAddWindowCapture("Trace","",""); Phase_pass++; }
        else             { testStepFail("FAIL"); testReportAddWindowCapture("Trace","",""); Phase_fail++; }
        DtcIndex++; READ_DTC--; ReadDTCInformation();
      }
      else
      {
        snprintf(Buffer, elcount(Buffer), "sub 0x06 complete - %d PASS / %d FAIL", Phase_pass, Phase_fail);
        testStep("Summary sub 0x06", Buffer);
        DtcIndex = 0; ReadDTCInformation();
      }
      break;

    /* case 24 â€” NRC Comprehensive (30 frames) */
    case 24:
      if (NrcIndex == 0) { testStep("", "NRC Comprehensive - 30 Frames"); Phase_pass = 0; Phase_fail = 0; }
      if (NrcIndex < 30)
      {
        byte expNRC; byte ok;
        Send_Raw_Frame(NRC_Frames[NrcIndex]);
        testWaitForTimeout(900);
        expNRC = ExpectedNRC[NrcIndex];
        if      (expNRC == 0x11) ok = ((SID_19 == 12)||(SID_19 == 16)) ? 1 : 0;
        else if (expNRC == 0x12) ok = (SID_19 == 13) ? 1 : 0;
        else if (expNRC == 0x13) ok = (SID_19 == 14) ? 1 : 0;
        else if (expNRC == 0x31) ok = (SID_19 == 15) ? 1 : 0;
        else                     ok = (SID_19 == 9)  ? 1 : 0;
        snprintf(Buffer, elcount(Buffer), "[Frame %02d] %s", NrcIndex + 1, NRC_Desc[NrcIndex]);
        testStep("", Buffer);
        if (ok) { testStepPass("PASS"); testReportAddWindowCapture("Trace","",""); Phase_pass++; }
        else    { testStepFail("FAIL"); testReportAddWindowCapture("Trace","",""); Phase_fail++; }
        NrcIndex++; READ_DTC--; ReadDTCInformation();
      }
      else
      {
        snprintf(Buffer, elcount(Buffer), "NRC tests complete - %d PASS / %d FAIL", Phase_pass, Phase_fail);
        testStep("Summary NRC", Buffer);
        NrcIndex = 0; ReadDTCInformation();
      }
      break;

    default:
      READ_DTC = 0;
      cancelTimer(Timer19);
      break;
  }
}

void TesterPresent()
{
  setTimer(Timer3E, 1000);
  TESTER_PRESENT++;
 
  switch (TESTER_PRESENT) 
  {
    case 1: 
      Send_Diag_Request(0x02, 0x10, session, 0x00, 0x00, 0x00, 0x00, 0x00);
      testWaitForTimeout(900);
      testStep("", "10.2.2.2 Request message SubFunction parameter $Level (LEV_) definition");
      snprintf(Buffer,elcount (Buffer), "10 - 0%X", session);  
      testStep("", Buffer);
      
      if ((SID_3E == 1) || (SID_3E == 4) || (SID_3E == 5)) 
      {
        testStepPass("PASS");
        TestReportAddWindowCapture("Trace", "", "");
      } 
      else 
      {
        testStepFail("FAIL");
        TestReportAddWindowCapture("Trace", "", "");
      }
      TesterPresent();  // Call the function again to move to the next READ_DATA_BY_IDENTIFIER
      break;
 
    case 2:
      Send_Diag_Request(0x02, 0x3E, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00);
      testWaitForTimeout(900);
      testStep("", "10.7.2.2 Request message SubFunction parameter $Level (LEV_) definition");
      testStep("", "3E 00");
      
      if(SID_3E == 2) 
      {
        testStepPass("PASS");
        TestReportAddWindowCapture("Trace", "", "");
      } 
      else 
      {
        testStepFail("FAIL");
        TestReportAddWindowCapture("Trace", "", "");
      }
      TesterPresent();  // Call next READ_DATA_BY_IDENTIFIER
      break;
 
    case 3:
      Send_Diag_Request(0x03, 0x3E, 0x80, 0x00, 0x00, 0x00, 0x00, 0x00);
      testWaitForTimeout(900);
      testStep("", "10.7.4 Supported negative response codes (NRC_)");
      testStep("", "NRC - 13");
      
      if(SID_3E == 3) 
      {
        testStepPass("PASS");
        TestReportAddWindowCapture("Trace", "", "");
      } 
      else 
      {
        testStepFail("FAIL");
        TestReportAddWindowCapture("Trace", "", "");
      }
      TesterPresent();  // Call next READ_DATA_BY_IDENTIFIER
      break;
 
    case 4:
      Send_Diag_Request(0x03, 0x3E, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00);
      testWaitForTimeout(900);
      testStep("", "10.7.4 Supported negative response codes (NRC_)");
      testStep("", "NRC - 13");
      
      if(SID_3E == 3) 
      {
        testStepPass("PASS");
        TestReportAddWindowCapture("Trace", "", "");
      } 
      else 
      {
        testStepFail("FAIL");
        TestReportAddWindowCapture("Trace", "", "");
      }
      TesterPresent();  // Call next READ_DATA_BY_IDENTIFIER
      break;
 
    case 5:
      Send_Diag_Request(0x02, 0x3E, 0x80, 0x00, 0x00, 0x00, 0x00, 0x00);
      testWaitForTimeout(900);
      testStep("", "10.7.2.2 Request message SubFunction parameter $Level (LEV_) definition");
      testStep("", "3E 80 - No response");
      
      testStepPass("PASS");
      TestReportAddWindowCapture("Trace", "", "");
      TesterPresent();  // Call next READ_DATA_BY_IDENTIFIER
      break;
      
    case 6:
      Send_Diag_Request(0x02, 0x3E, 0x01, 0x00, 0x00, 0x00, 0x00, 0x00);
      testWaitForTimeout(900);
      testStep("", "10.7.4 Supported negative response codes (NRC_)");
      testStep("", "NRC - 12");
      
      if(SID_3E == 6) 
      {
        testStepPass("PASS");
        TestReportAddWindowCapture("Trace", "", "");
      } 
      else 
      {
        testStepFail("FAIL");
        TestReportAddWindowCapture("Trace", "", "");
      }
      TesterPresent();  // Call next READ_DATA_BY_IDENTIFIER
      break;
      
    case 7:
      Send_Diag_Request(2, 0x10, 0x01, IDLE, IDLE, IDLE, IDLE, IDLE);  // Default session
      testWaitForTimeout (900);
      TesterPresent();  // Call next READ_DATA_BY_IDENTIFIER
      break;
 
    default:
      session++;
      if(session ==2 || session ==3)
      {
      traceWindowClear("Trace");
      }
      TESTER_PRESENT = 0;
      if (session == 4) 
      {
        cancelTimer(Timer3E);
        session = 1;
      } else {
        TesterPresent();  // Restart session
      }
      break;
  }
}

void ClearDiagnosticInformation()
{
  setTimer (Timer14, 1000);
  CLEAR_DIAGNOSTIC_INFORMATION++;
  
  switch (CLEAR_DIAGNOSTIC_INFORMATION)
  {
    case 1:
      Send_Diag_Request(2, 0x10, session, IDLE, IDLE, IDLE, IDLE, IDLE); // 0x10 - session type
      testWaitForTimeout (900);
      testStep("", "10.2.2.2 Request message SubFunction parameter $Level (LEV_) definition");
      snprintf(Buffer,elcount (Buffer), "10 - 0%X", session);  
      testStep("", Buffer);
      
      if ((SID_14 == 1) || (SID_14 == 2) || (SID_14 == 3))
      {
        testStepPass("PASS");
        testReportAddWindowCapture("Trace", "", "");
      }
      else
      {
        testStepFail("FAIL");
        testReportAddWindowCapture("Trace", "", "");
      }
      ClearDiagnosticInformation();
      break;
      
    case 2:
      Send_Diag_Request(4, 0x14, 0xFF, 0xFF, 0xFF, IDLE, IDLE, IDLE); // 14 - FF FF FF
      testWaitForTimeout (900);
      testStep("", "12.2.2.1 Request message definition");
      testStep("", "14 FF FF FF");
      
      if (SID_14 == 4)
      {
        testStepPass("PASS");
        testReportAddWindowCapture("Trace", "", "");
      }
      else
      {
        testStepFail("FAIL");
        testReportAddWindowCapture("Trace", "", "");
      }
      ClearDiagnosticInformation();
      break;
      
    case 3:
      Send_Diag_Request(1, 0x14, 0xFF, 0xFF, 0xFF, IDLE, IDLE, IDLE); // NRC - 13
      testWaitForTimeout (900);
      testStep("", "12.2.4 Supported negative response codes (NRC_)");
      testStep("", "NRC - 13");
      
      if (SID_14 == 5)
      {
        testStepPass("PASS");
        testReportAddWindowCapture("Trace", "", "");
      }
      else
      {
        testStepFail("FAIL");
        testReportAddWindowCapture("Trace", "", "");
      }
      ClearDiagnosticInformation();
      break;
      
    case 4:
      Send_Diag_Request(4, 0x41, 0xFF, 0xFF, 0xFF, IDLE, IDLE, IDLE); // NRC - 11
      testWaitForTimeout (900);
      testStep("", "12.2.4 Supported negative response codes (NRC_)");
      testStep("", "NRC - 11");
      
      if (SID_14 == 6)
      {
        testStepPass("PASS");
        testReportAddWindowCapture("Trace", "", "");
      }
      else
      {
        testStepFail("FAIL");
        testReportAddWindowCapture("Trace", "", "");
      }
      ClearDiagnosticInformation();
      break;
    
    case 5:
      Send_Diag_Request(4, 0x14, 0xFF, 0xFF, 0xFE, IDLE, IDLE, IDLE); // NRC - 31
      testWaitForTimeout (900);
      testStep("", "12.2.4 Supported negative response codes (NRC_)");
      testStep("", "NRC - 31");
      
      if (SID_14 == 7)
      {
        testStepPass("PASS");
        testReportAddWindowCapture("Trace", "", "");
      }
      else
      {
        testStepFail("FAIL");
        testReportAddWindowCapture("Trace", "", "");
      }
      ClearDiagnosticInformation();
      break;
      
    case 6:
      Send_Diag_Request(2, 0x10, 0x01, IDLE, IDLE, IDLE, IDLE, IDLE);  // Default session
      testWaitForTimeout (900);
      ClearDiagnosticInformation();
      break;
      
    default:
      session++;
      if ((session == 2) || (session == 3))
      {
        traceWindowClear("Trace");
      }
      CLEAR_DIAGNOSTIC_INFORMATION = 0;
      if (session == 4)
      {
        cancelTimer (Timer14);
        session = 1;
      }
      else 
      {
        ClearDiagnosticInformation();  
      }
      break;
  }
}

void ReadMemoryByAddress ()
{
  setTimer (Timer23, 1000);
  READ_MEMORY_BY_ADDRESS++;
  
  switch (READ_MEMORY_BY_ADDRESS)
  {
    case 1:
      Send_Diag_Request(2, 0x10, session, IDLE, IDLE, IDLE, IDLE, IDLE); // 0x10 - session type
      testWaitForTimeout (900);
      testStep("", "10.2.2.2 Request message SubFunction parameter $Level (LEV_) definition");
      snprintf(Buffer,elcount (Buffer), "10 - 0%X", session);  
      testStep("", Buffer);
      
      if ((SID_23 == 1) || (SID_23 == 2) || (SID_23 == 3))
      {
        testStepPass("PASS");
        testReportAddWindowCapture("Trace", "", "");
      }
      else
      {
        testStepFail("FAIL");
        testReportAddWindowCapture("Trace", "", "");
      }
      if (session == 1)
      {
        READ_MEMORY_BY_ADDRESS = 4;
      }
      ReadMemoryByAddress();
      break;
      
    case 2:
      if ((session == 2) || (session == 3))
      {
        Send_Diag_Request(7, 0x23, addresslength, memoryaddress1, memoryaddress2, memoryaddress3, memoryaddress4, memorysize);  // NRC 33
      }
      testWaitForTimeout (900);
      testStep("", "11.3.2.1 Request message definition");
      testStep("", "NRC - 33");
      
