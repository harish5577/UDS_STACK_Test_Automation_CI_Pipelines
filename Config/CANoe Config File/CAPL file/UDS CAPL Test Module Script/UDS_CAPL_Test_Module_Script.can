      if ((session == 1) && (SID_22 == 21))
      {
        testStep("", "NRC - 33"); 
        testStepPass("PASS");
        testReportAddWindowCapture("Trace", "", "");
      }
      else if (((session == 2) || (session == 3)) && (SID_22 == 18))
      {
