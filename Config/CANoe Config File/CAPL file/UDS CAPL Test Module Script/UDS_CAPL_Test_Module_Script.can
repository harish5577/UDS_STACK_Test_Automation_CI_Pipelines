        testStepFail("FAIL");
        testReportAddWindowCapture("Trace", "", "");
      }
      RoutineControl();
      break;
      
    case 13:
      Send_Diag_Request(2, 0x10, 0x01, IDLE, IDLE, IDLE, IDLE, IDLE); // Default session
      testWaitForTimeout (900);
      RoutineControl();
      break;
      
    default:
      session += 1;
      if ((session == 2) || (session == 3))
      {
        traceWindowClear("Trace");
      }
      ROUTINE_CONTROL = 0;
      routine_1 = 0;
      routine_2 = 0;
      routine_3 = 0;
      routine_cycle = 0;
      
      if (session == 4)
      {
        cancelTimer (Timer31);
        session = 1;
      }
      else 
      {
        RoutineControl();
      }
      break;
  }
}

