      else if (((session == 2) || (session == 3)) && (SID_31 == 15))
      {
        testStep("", "NRC - 24");
      }
      
      if (((session == 1 ) && (SID_31 == 16)) || (((session == 2) || (session == 3)) && (SID_31 == 15)))
      {
        testStepPass("PASS");
        testReportAddWindowCapture("Trace", "", "");
      }
      else
      {
        testStepFail("FAIL");
        testReportAddWindowCapture("Trace", "", "");
      }
      routine_1 = routine_2 = routine_3 = 0;
      RoutineControl();
      break;
      
    case 5:
      if (routine_1 < 3)
      {
        Send_Diag_Request(4, 0x31, routine_1 + 1, RID[routine_cycle][0], RID[routine_cycle][1], IDLE, IDLE, IDLE);  // 31 - 23 45
