void ECUReset()
{
  setTimer(Timer11, 1000);
  ECU_RESET++;

  switch(ECU_RESET) 
  {
    case 1:  
      Send_Diag_Request(0x02, 0x10, session, 0x00, 0x00, 0x00, 0x00, 0x00);
      testWaitForTimeout (900);
      testStep("", "10.2.2.2 Request message SubFunction parameter $Level (LEV_) definition");
      snprintf(Buffer,elcount (Buffer), "10 - 0%X", session);  
      testStep("", Buffer);
  
      if ((SID_11 == 1) || (SID_11 == 2) || (SID_11 == 3))
      {
        testStepPass("PASS");
        testReportAddWindowCapture("Trace", "", "");
      }
      else
      {
        testStepFail("FAIL");
        testReportAddWindowCapture("Trace", "", "");
      }
      ECUReset();
      break;

    case 2: 
      testStep("", "10.3.2.2 Request message SubFunction Parameter $Level (LEV_) definition");
      if (resetCount < 6) 
      {
        Send_Diag_Request(0x02, 0x11, resetCount, 0x00, 0x00, 0x00, 0x00, 0x00);
        snprintf(Buffer,elcount (Buffer), "11 - 0%x", resetCount);  
        testStep("", Buffer);
        resetCount++;
        ECU_RESET--;
      } 
      testWaitForTimeout (900);
  
      if ((SID_11 == 4) || (SID_11 == 5) || (SID_11 == 6) || (SID_11 == 7) || (SID_11 == 8))
      {
        testStepPass("PASS");
        testReportAddWindowCapture("Trace", "", "");
      }
      else
      {
        testStepFail("FAIL");
        testReportAddWindowCapture("Trace", "", "");
      }
      ECUReset();
      break;

    case 3:
      Send_Diag_Request(0x03, 0x11, 0x01, 0x00, 0x00, 0x00, 0x00, 0x00);
      testWaitForTimeout (900);
      testStep("", "10.3.4 Supported negative response codes (NRC_)");
      testStep("", "NRC - 13");
  
      if (SID_11 == 9)
      {
        testStepPass("PASS");
        testReportAddWindowCapture("Trace", "", "");
      }
      else
      {
        testStepFail("FAIL");
        testReportAddWindowCapture("Trace", "", "");
      }
      ECUReset();
      break;

    case 4:
      Send_Diag_Request(0x02, 0x11, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00);
      testWaitForTimeout (900);
      testStep("", "10.3.4 Supported negative response codes (NRC_)");
      testStep("", "NRC - 12");
  
      if (SID_11 == 10)
      {
        testStepPass("PASS");
        testReportAddWindowCapture("Trace", "", "");
      }
      else
      {
        testStepFail("FAIL");
        testReportAddWindowCapture("Trace", "", "");
      }
      ECUReset();
      break;

    case 5:
      Send_Diag_Request(0x02, 0x18, 0x01, 0x00, 0x00, 0x00, 0x00, 0x00);
      testWaitForTimeout (900);
      testStep("", "10.3.4 Supported negative response codes (NRC_)");
      testStep("", "NRC - 11");
  
      if (SID_11 == 11)
      {
        testStepPass("PASS");
        testReportAddWindowCapture("Trace", "", "");
      }
      else
      {
        testStepFail("FAIL");
        testReportAddWindowCapture("Trace", "", "");
      }
      ECUReset();
      break;

    case 6:
      Send_Diag_Request(2, 0x10, 0x01, IDLE, IDLE, IDLE, IDLE, IDLE); // Default session
      testWaitForTimeout (900);
      ECUReset();
      break;
      
    default:
      session += 1;
      resetCount = 1;
      if ((session == 2) || (session == 3))
      {
        traceWindowClear("Trace");
      }
      ECU_RESET = 0;
      if (session == 4)
      {
        cancelTimer (Timer11);
        session = 1;
      }
      else
      {
        ECUReset(); 
      }
      break;
  }
}

void WriteMemoryByAddress()
{
  setTimer (Timer3D, 1000);
  WRITE_MEMORY_BY_ADDRESS++;
  
  switch (WRITE_MEMORY_BY_ADDRESS)
  {
    case 1:
      Send_Diag_Request(2, 0x10, session, 0x00, 0x00, 0x00, 0x00, 0x00); // 0x10 - session type
      testWaitForTimeout (900);
      testStep("", "10.2.2.2 Request message SubFunction parameter $Level (LEV_) definition");
      snprintf(Buffer,elcount (Buffer), "10 - 0%X", session);  
      testStep("", Buffer);
      
      if ((SID_3D == 1) || (SID_3D == 2) || (SID_3D == 3))
      {
        testStepPass("PASS");
        testReportAddWindowCapture("Trace", "", "");
      }
      else
      {
        testStepFail("FAIL");
        testReportAddWindowCapture("Trace", "", "");
      }
      WriteMemoryByAddress();
      break;
      
    case 2:
      Send_Diag_Request(7, 0x3D, addresslength, memoryaddress1, memoryaddress2, memoryaddress3, memoryaddress4, memorysize);  // NRC 33
      if (session == 1)
      {
        WRITE_MEMORY_BY_ADDRESS = 4;
      }
      testWaitForTimeout (900);
      testStep("", "11.8.4 Supported negative response codes (NRC_)");
      testStep("", "NRC - 33");
      
      if (SID_3D == 4)
      {
        testStepPass("PASS");
        testReportAddWindowCapture("Trace", "", "");
      }
      else
      {
        testStepFail("FAIL");
        testReportAddWindowCapture("Trace", "", "");
      }
      WriteMemoryByAddress();
      break;
      
    case 3:
      if ((session == 2) || (session == 3))
      { 
        Send_Diag_Request(2, 0x27, 01, 0, 0, 0, 0, 0); // 27 01
        WRITE_MEMORY_BY_ADDRESS = 3;
      }
      testWaitForTimeout (900);
      testStep("", "10.4.2.2 Request message SubFunction parameter $Level (LEV_) definition");
      testStep("", "27 01");
      
      if (SID_3D == 5)
      {
        testStepPass("PASS");
        testReportAddWindowCapture("Trace", "", "");
      }
      else
      {
        testStepFail("FAIL");
        testReportAddWindowCapture("Trace", "", "");
      }
      WriteMemoryByAddress();
      break;
      
    case 4:
      Send_Diag_Request(5, 0x27, 0x02, 0x35, 0xA3, 0x6C, 0x00, 0x00);  // 27 02
      testWaitForTimeout (900);
      testStep("", "10.4.2.2 Request message SubFunction parameter $Level (LEV_) definition");
      testStep("", "27 02");
      
      if (SID_3D == 6)
      {
        testStepPass("PASS");
        testReportAddWindowCapture("Trace", "", "");
      }
      else
      {
        testStepFail("FAIL");
        testReportAddWindowCapture("Trace", "", "");
      }
      WriteMemoryByAddress();
      break;
      
    case 5:
      Send_Diag_Request(7, 0x3D, addresslength, memoryaddress1, memoryaddress2, memoryaddress3, memoryaddress4, memorysize);  // 3D
      testWaitForTimeout (900);
      testStep("", "11.8.2.1 Request message definition");
      testStep("", "3D");
      
      if (((session == 1 ) && (SID_3D == 4)) || (((session == 2) || (session == 3)) && (SID_3D == 7)))
      {
        testStepPass("PASS");
        testReportAddWindowCapture("Trace", "", "");
      }
      else
      {
        testStepFail("FAIL");
        testReportAddWindowCapture("Trace", "", "");
      }
      WriteMemoryByAddress();
      
      break;
      
    case 6:
      Send_Diag_Request(4, 0x3D, addresslength, memoryaddress1, memoryaddress2, memoryaddress3, memoryaddress4, memorysize);  // NRC 13
      testWaitForTimeout (900);
      testStep("", "11.8.4 Supported negative response codes (NRC_)");
      testStep("", "NRC - 13");
      
      if (((session == 1 ) && (SID_3D == 4)) || (((session == 2) || (session == 3)) && (SID_3D == 8)))
      {
        testStepPass("PASS");
        testReportAddWindowCapture("Trace", "", "");
      }
      else
      {
        testStepFail("FAIL");
        testReportAddWindowCapture("Trace", "", "");
      }
      WriteMemoryByAddress();
      break;
      
    case 7:
      Send_Diag_Request(7, 0x33, addresslength, memoryaddress1, memoryaddress2, memoryaddress3, memoryaddress4, memorysize);  // NRC 11
      testWaitForTimeout (900);
      testStep("", "11.8.4 Supported negative response codes (NRC_)");
      testStep("", "NRC - 11");
      
      if (SID_3D == 9)
      {
        testStepPass("PASS");
        testReportAddWindowCapture("Trace", "", "");
      }
      else
      {
        testStepFail("FAIL");
        testReportAddWindowCapture("Trace", "", "");
      }
      WriteMemoryByAddress();
      break;
      
    case 8:
      Send_Diag_Request(7, 0x3D, 0x41, memoryaddress1, memoryaddress2, memoryaddress3, memoryaddress4, memorysize);  // NRC 31
      testWaitForTimeout (900);
      testStep("", "11.8.4 Supported negative response codes (NRC_)");
      testStep("", "NRC - 31");
      
      if (((session == 1 ) && (SID_3D == 4)) || (((session == 2) || (session == 3)) && (SID_3D == 10)))
      {
        testStepPass("PASS");
        testReportAddWindowCapture("Trace", "", "");
      }
      else
      {
        testStepFail("FAIL");
        testReportAddWindowCapture("Trace", "", "");
      }
      WriteMemoryByAddress();
      break;
      
    case 9:
      Send_Diag_Request(2, 0x10, 0x01, IDLE, IDLE, IDLE, IDLE, IDLE); // Default session
      testWaitForTimeout (900);
      WriteMemoryByAddress();
      break;
      
    default:
      session += 1;
      if ((session == 2) || (session == 3))
      {
        traceWindowClear("Trace");
      }
      WRITE_MEMORY_BY_ADDRESS = 0;
      if (session == 4)
      {
        cancelTimer (Timer3D);
      }
      else
      {
        WriteMemoryByAddress();
      }
      break;
  }
}

void ReadDataByIdentifier() 
{
  setTimer(Timer22, 1000);
  READ_DATA_BY_IDENTIFIER++;
  
  switch (READ_DATA_BY_IDENTIFIER) 
  {
    case 1: 
      Send_Diag_Request(0x02, 0x10, session, 0x00, 0x00, 0x00, 0x00, 0x00);
      testWaitForTimeout (900); 
      testStep("", "10.2.2.2 Request message SubFunction parameter $Level (LEV_) definition");
      snprintf(Buffer,elcount (Buffer), "10 - 0%X", session);  
      testStep("", Buffer);
  
      if ((SID_22 == 1) || (SID_22 == 2) || (SID_22 == 3))
      {
        testStepPass("PASS");
        testReportAddWindowCapture("Trace", "", "");
      }
      else
      {
        testStepFail("FAIL");
        testReportAddWindowCapture("Trace", "", "");
      }
      if (session == 1) 
      {
        READ_DATA_BY_IDENTIFIER = 4; 
      } 
      else if ((session == 2) || (session == 3))
      {
        READ_DATA_BY_IDENTIFIER = 1; 
      }
      ReadDataByIdentifier();
      break;
      
    case 2:
      Send_Diag_Request(0x03, 0x22, 0xF1, 0x8C, 0x00, 0x00, 0x00, 0x00);
      testWaitForTimeout (900);
      testStep("", "11.2.4 Supported negative response codes (NRC_)");
      testStep("", "NRC - 33");
      
      if (SID_22 == 21)
      {
        testStepPass("PASS");
        testReportAddWindowCapture("Trace", "", "");
      }
      else
      {
        testStepFail("FAIL");
        testReportAddWindowCapture("Trace", "", "");
      }
      ReadDataByIdentifier();
      break;
      
    case 3: 
      Send_Diag_Request(2, 0x27, 0x01, 0x00, 0x00, 0x00, 0x00, 0x00);
      testWaitForTimeout (900);
      testStep("", "10.4.2.2 Request message SubFunction parameter $Level (LEV_) definition");
      testStep("", "27 01");
      
      if (SID_22 == 4)
      {
        testStepPass("PASS");
        testReportAddWindowCapture("Trace", "", "");
      }
      else
      {
        testStepFail("FAIL");
        testReportAddWindowCapture("Trace", "", "");
      }
      ReadDataByIdentifier();
      break;
      
    case 4: 
