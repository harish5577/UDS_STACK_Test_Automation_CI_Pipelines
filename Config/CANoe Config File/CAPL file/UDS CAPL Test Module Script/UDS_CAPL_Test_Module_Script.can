        snprintf(Buffer,elcount (Buffer), "22 - %X %X", DID[didIndex][0], DID[didIndex][1]);  
        testStep("", Buffer); 
        didIndex++;
        READ_DATA_BY_IDENTIFIER--;
      } 
      testWaitForTimeout (900); 
      
      if ((session == 1) && (SID_22 == 21))
      {
        testStep("", "NRC - 33"); 
        testStepPass("PASS");
        testReportAddWindowCapture("Trace", "", "");
      }
      else if (((session == 2) || (session == 3)) && ((SID_22 == 6) || (SID_22 == 7) || (SID_22 == 8) || (SID_22 == 9) || (SID_22 == 10) || (SID_22 == 11) || (SID_22 == 12) || (SID_22 == 13) || (SID_22 == 14) || (SID_22 == 15) || (SID_22 == 16) || (SID_22 == 17)))
      {
        testStepPass("PASS");
