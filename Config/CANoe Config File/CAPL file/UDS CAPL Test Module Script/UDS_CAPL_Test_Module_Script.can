void RoutineControl()
{
  setTimer (Timer31, 1000);
  ROUTINE_CONTROL++;
  
  switch (ROUTINE_CONTROL)
  {
    case 1:
      Send_Diag_Request(2, 0x10, session, IDLE, IDLE, IDLE, IDLE, IDLE); // 0x10 - session type
      testWaitForTimeout (900);
      testStep("", "10.2.2.2 Request message SubFunction parameter $Level (LEV_) definition");
      snprintf(Buffer,elcount (Buffer), "10 - 0%X", session);  
      testStep("", Buffer);
      
      if ((SID_31 == 1) || (SID_31 == 2) || (SID_31 == 3))
      {
        testStepPass("PASS");
        testReportAddWindowCapture("Trace", "", "");
      }
      else
      {
        testStepFail("FAIL");
        testReportAddWindowCapture("Trace", "", "");
      }
      if (session == 1)
      {
        ROUTINE_CONTROL = 3;
      }
      RoutineControl();
      break;
      
    case 2:
      if ((session == 2) || (session == 3))
      { 
        Send_Diag_Request(2, 0x27, 01, IDLE, IDLE, IDLE, IDLE, IDLE); // 27 01
        ROUTINE_CONTROL = 2;
      }
      testWaitForTimeout (900);
      testStep("", "10.4.2.2 Request message SubFunction parameter $Level (LEV_) definition");
      testStep("", "27 01");
      
      if (SID_31 == 4)
      {
        testStepPass("PASS");
        testReportAddWindowCapture("Trace", "", "");
      }
      else
      {
        testStepFail("FAIL");
        testReportAddWindowCapture("Trace", "", "");
      }
      RoutineControl();
      break;
      
