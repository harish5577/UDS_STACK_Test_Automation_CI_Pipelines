/***********************************************************************************************************************
 *                                      T I M E R   D E F I N I T I O N S
 ***********************************************************************************************************************/
on timer Timer3E
{
  TesterPresent();
}

on timer Timer14
{
  ClearDiagnosticInformation();
}

on timer Timer23
{
  ReadMemoryByAddress();
}

on timer Timer27
{
  SecurityAccess();
}

on timer Timer83
{
  AccessTimingParameter();
}

on timer Timer29
{
  Authentication();
}

on timer Timer86
{
  ResponseOnEvent();
}

on timer Timer31
{
  RoutineControl();
}

on timer Timer2C
{
  DynamicallyDefineDataIdentifier();
}

on timer Timer11
{
  ECUReset();
}

on timer Timer3D
{
  WriteMemoryByAddress();
}

on timer Timer22
{
  ReadDataByIdentifier();
}

on timer Timer2A
{
  ReadDataByPeriodicIdentifier();
}

on timer Timer2F
{
  InputOutputControlByIdentifier();
}

on timer Timer19
{
  ReadDTCInformation();
}

/***********************************************************************************************************************
 *                                       F U N C T I O N   D E F I N I T I O N S
 ***********************************************************************************************************************/
void Init()
{
  /* DLC for 0x7E4 Message*/
  frame_receive.dlc = 8;
  frame_transmit.dlc = 8;

  /* TIMER CONFIGURED FOR 250 US */
  setTimer(TP_Timer, 0, TP_TASK_RATE_IN_MICRO_SECONDS * 1000);
  write ("Ready to Start");
}

/* Function to send the request frame */
void Send_Diag_Request(byte dlc, byte service_id, byte sub_function, byte byte3, byte byte4, byte byte5, byte byte6, byte byte7) 
{
  Dia_Req.byte(0) = dlc;
  Dia_Req.byte(1) = service_id;
  Dia_Req.byte(2) = sub_function;
  Dia_Req.byte(3) = byte3;
  Dia_Req.byte(4) = byte4;
  Dia_Req.byte(5) = byte5;
  Dia_Req.byte(6) = byte6;
  Dia_Req.byte(7) = byte7;

  output (Dia_Req);
  write ("Send request: 0x%02X, 0x%02X, 0x%02X, 0x%02X\n", dlc, service_id, sub_function, byte3);
}

void Send_Raw_Frame(byte frame[])
{
  int i;
  for (i = 0; i < 8; i++) Dia_Req.byte(i) = frame[i];
  output(Dia_Req);
  write("TX_RAW: %02X %02X %02X %02X %02X %02X %02X %02X",
        frame[0],frame[1],frame[2],frame[3],
        frame[4],frame[5],frame[6],frame[7]);
}

void ReadDTCInformation()
{
  setTimer(Timer19, 1000);
  READ_DTC++;

  switch (READ_DTC)
  {
    /* case 1 â€” Session entry: 10 01 */
    case 1:
      Send_Diag_Request(0x02, 0x10, 0x01, IDLE, IDLE, IDLE, IDLE, IDLE);
      testWaitForTimeout(900);
      testStep("", "10.2.2.2 Request message SubFunction - defaultSession");
      testStep("", "10 01");
      if (SID_19 == 1)
      { testStepPass("PASS"); testReportAddWindowCapture("Trace","",""); }
      else
      { testStepFail("FAIL"); testReportAddWindowCapture("Trace","",""); }
      ReadDTCInformation();
      break;

    /* sub 0x01 reportNumberOfDTCByStatusMask */
    case 2:
      Send_Diag_Request(0x03, 0x19, 0x01, 0x29, IDLE, IDLE, IDLE, IDLE);
      testWaitForTimeout(900);
      testStep("", "12.3.2.2 sub 0x01 - reportNumberOfDTCByStatusMask");
      testStep("", "19 01 29 (statusMask=0x29)");
      if (SID_19 == 4)
      { testStepPass("PASS"); testReportAddWindowCapture("Trace","",""); }
      else
      { testStepFail("FAIL"); testReportAddWindowCapture("Trace","",""); }
      ReadDTCInformation();
      break;

    case 3:
      Send_Diag_Request(0x02, 0x19, 0x01, 0x29, IDLE, IDLE, IDLE, IDLE);
      testWaitForTimeout(900);
      testStep("", "12.3.4 NRC 13 - incorrectMessageLength (sub 0x01, DLC=2)");
      if (SID_19 == 14)
      { testStepPass("PASS"); testReportAddWindowCapture("Trace","",""); }
      else
      { testStepFail("FAIL"); testReportAddWindowCapture("Trace","",""); }
      ReadDTCInformation();
      break;

    case 4:
      Send_Diag_Request(0x03, 0x91, 0x01, 0x29, IDLE, IDLE, IDLE, IDLE);
      testWaitForTimeout(900);
      testStep("", "NRC 11 - serviceNotSupported (SID=0x91)");
      if (SID_19 == 16)
      { testStepPass("PASS"); testReportAddWindowCapture("Trace","",""); }
      else
      { testStepFail("FAIL"); testReportAddWindowCapture("Trace","",""); }
      ReadDTCInformation();
      break;

    case 5:
      Send_Diag_Request(0x03, 0x19, 0x00, 0x29, IDLE, IDLE, IDLE, IDLE);
      testWaitForTimeout(900);
      testStep("", "NRC 12 - subFunctionNotSupported (sub=0x00)");
      if (SID_19 == 13)
      { testStepPass("PASS"); testReportAddWindowCapture("Trace","",""); }
      else
      { testStepFail("FAIL"); testReportAddWindowCapture("Trace","",""); }
      ReadDTCInformation();
      break;

    /* sub 0x02 reportDTCByStatusMask */
    case 6:
      Send_Diag_Request(0x03, 0x19, 0x02, 0x29, IDLE, IDLE, IDLE, IDLE);
      testWaitForTimeout(900);
      testStep("", "12.3.2.2 sub 0x02 - reportDTCByStatusMask");
      if (SID_19 == 5)
      { testStepPass("PASS"); testReportAddWindowCapture("Trace","",""); }
      else
      { testStepFail("FAIL"); testReportAddWindowCapture("Trace","",""); }
      ReadDTCInformation();
      break;

    case 7:
      Send_Diag_Request(0x02, 0x19, 0x02, 0x00, IDLE, IDLE, IDLE, IDLE);
      testWaitForTimeout(900);
      testStep("", "NRC 13 - incorrectMessageLength (sub 0x02, DLC=2)");
      if (SID_19 == 14)
      { testStepPass("PASS"); testReportAddWindowCapture("Trace","",""); }
      else
      { testStepFail("FAIL"); testReportAddWindowCapture("Trace","",""); }
      ReadDTCInformation();
      break;

    /* sub 0x03 reportDTCSnapshotIdentification */
    case 8:
      Send_Diag_Request(0x02, 0x19, 0x03, IDLE, IDLE, IDLE, IDLE, IDLE);
      testWaitForTimeout(900);
      testStep("", "12.3.2.2 sub 0x03 - reportDTCSnapshotIdentification");
      if (SID_19 == 6)
      { testStepPass("PASS"); testReportAddWindowCapture("Trace","",""); }
      else
      { testStepFail("FAIL"); testReportAddWindowCapture("Trace","",""); }
      ReadDTCInformation();
      break;

    case 9:
      Send_Diag_Request(0x03, 0x19, 0x03, 0x29, IDLE, IDLE, IDLE, IDLE);
      testWaitForTimeout(900);
      testStep("", "NRC 13 - incorrectMessageLength (sub 0x03, extra byte)");
      if (SID_19 == 14)
      { testStepPass("PASS"); testReportAddWindowCapture("Trace","",""); }
      else
      { testStepFail("FAIL"); testReportAddWindowCapture("Trace","",""); }
      ReadDTCInformation();
      break;

    /* sub 0x0A reportSupportedDTCs */
    case 10:
      Send_Diag_Request(0x02, 0x19, 0x0A, IDLE, IDLE, IDLE, IDLE, IDLE);
      testWaitForTimeout(900);
      testStep("", "12.3.2.2 sub 0x0A - reportSupportedDTCs");
