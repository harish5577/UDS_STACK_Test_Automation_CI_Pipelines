        testStepPass("PASS");
        testReportAddWindowCapture("Trace", "", "");
      }
      else
      {
        testStepFail("FAIL");
        testReportAddWindowCapture("Trace", "", "");
      }
      ReadDataByIdentifier();
      break;
      
    case 7:
      Send_Diag_Request(0x03, 0x21, 0xF1, 0x8C, 0x00, 0x00, 0x00, 0x00);
      testWaitForTimeout (900);
      testStep("", "11.2.4 Supported negative response codes (NRC_)");
      testStep("", "NRC - 11");
      
      if (SID_22 == 19)
      {
        testStepPass("PASS");
        testReportAddWindowCapture("Trace", "", "");
      }
      else
      {
        testStepFail("FAIL");
        testReportAddWindowCapture("Trace", "", "");
      }
      ReadDataByIdentifier();
      break;
      
    case 8:
      Send_Diag_Request(0x03, 0x22, 0xF1, 0x8A, 0x00, 0x00, 0x00, 0x00);
      testWaitForTimeout (900);
      testStep("", "11.2.4 Supported negative response codes (NRC_)");
      
      if ((session == 1) && (SID_22 == 21))
      {
        testStep("", "NRC - 33"); 
        testStepPass("PASS");
        testReportAddWindowCapture("Trace", "", "");
      }
      else if (((session == 2) || (session == 3)) && (SID_22 == 20))
      {
        testStep("", "NRC - 31");
        testStepPass("PASS");
        testReportAddWindowCapture("Trace", "", "");
      }
      else
      {
        testStepFail("FAIL");
        testReportAddWindowCapture("Trace", "", "");
      }
      
      ReadDataByIdentifier();
      break;
      
    case 9:
      Send_Diag_Request(2, 0x10, 0x01, IDLE, IDLE, IDLE, IDLE, IDLE); // Default session
      testWaitForTimeout (900);
      ReadDataByIdentifier();
      break;
      
    default:
      session += 1;
      didIndex = 0;
      if ((session == 2) || (session == 3))
      {
        traceWindowClear("Trace");
      }
      READ_DATA_BY_IDENTIFIER = 0;
      if (session == 4)
      {
        cancelTimer (Timer22);
      }
      else
      {
        ReadDataByIdentifier();
      }
      break;
  }
}

void ReadDataByPeriodicIdentifier() 
{
  setTimer(Timer2A, 1000);
  READ_DATA_BY_PERIODIC_IDENTIFIER++;
  
  switch (READ_DATA_BY_PERIODIC_IDENTIFIER)
  {
    case 1: 
      Send_Diag_Request(0x02, 0x10, session, 0x00, 0x00, 0x00, 0x00, 0x00);
      testWaitForTimeout (900);
      testStep("", "10.2.2.2 Request message SubFunction parameter $Level (LEV_) definition");
      snprintf(Buffer,elcount (Buffer), "10 - 0%X", session);  
      testStep("", Buffer);
      
      if ((SID_2A == 1) || (SID_2A == 2) || (SID_2A == 3))
      {
        testStepPass("PASS");
        testReportAddWindowCapture("Trace", "", "");
      }
      else
      {
        testStepFail("FAIL");
        testReportAddWindowCapture("Trace", "", "");
      }
      if (session == 1) 
      {
        READ_DATA_BY_PERIODIC_IDENTIFIER = 4;  // Skip security access and move to DID reading
      } 
      else if (session == 2 || session == 3) 
      {
        READ_DATA_BY_PERIODIC_IDENTIFIER = 1;  // Proceed with security access
      }
      ReadDataByPeriodicIdentifier();
      break;
      
    case 2:
      Send_Diag_Request(0x03, 0x2A, 0x01, 0x45, 0x00, 0x00, 0x00, 0x00);    
      testWaitForTimeout (900);
      testStep("", "11.5.4 Supported negative response codes (NRC_)");
      testStep("", "NRC - 33");
      
      if (SID_2A == 8)
      {
        testStepPass("PASS");
        testReportAddWindowCapture("Trace", "", "");
      }
      else
      {
        testStepFail("FAIL");
        testReportAddWindowCapture("Trace", "", "");
      }
      ReadDataByPeriodicIdentifier();
      break;
      
      
    case 3: 
      Send_Diag_Request(2, 0x27, 0x01, 0x00, 0x00, 0x00, 0x00, 0x00);
      testWaitForTimeout (900);
      testStep("", "10.4.2.2 Request message SubFunction parameter $Level (LEV_) definition");
      testStep("", "27 01");
      
      if (SID_2A == 4)
      {
        testStepPass("PASS");
        testReportAddWindowCapture("Trace", "", "");
      }
      else
      {
        testStepFail("FAIL");
        testReportAddWindowCapture("Trace", "", "");
      }
      ReadDataByPeriodicIdentifier();
      break;
      
    case 4: 
      Send_Diag_Request(5, 0x27, 0x02, 0x35, 0xA3, 0x6C, 0x00, 0x00);
      testWaitForTimeout (900);
      testStep("", "10.4.2.2 Request message SubFunction parameter $Level (LEV_) definition");
      testStep("", "27 02");
      
      if (SID_2A == 5) 
      {
        testStepPass("PASS");
        testReportAddWindowCapture("Trace", "", "");
      }
      else
      {
        testStepFail("FAIL");
        testReportAddWindowCapture("Trace", "", "");
      }
      ReadDataByPeriodicIdentifier();
      break;
      
    case 5:
      testStep("", "11.5.2.3 Request message data-parameter definition");
      if (didIndex < 2) 
      {          
        Send_Diag_Request(0x03, 0x2A, transmission_mode + 1, PERIODIC_DID[didIndex], 0x00, 0x00, 0x00, 0x00);
        snprintf(Buffer,elcount (Buffer), "2A - 0%X %x", transmission_mode + 1, PERIODIC_DID[didIndex]);  
        testStep("", Buffer);
        transmission_mode++;
        READ_DATA_BY_PERIODIC_IDENTIFIER--;
        if (transmission_mode == 4) 
        {
          transmission_mode = 0;
          didIndex++;
        }
      }
      testWaitForTimeout (900);
      
      if ((session == 1) && (SID_2A == 8))
      {
        testStep("", "NRC - 33"); 
        testStepPass("PASS");
        testReportAddWindowCapture("Trace", "", "");
      }
      else if (((session == 2) || (session == 3)) && ((SID_2A == 6) || (SID_2A == 7)))
      {
        testStepPass("PASS");
        testReportAddWindowCapture("Trace", "", "");
      }
      else
      {
        testStepFail("FAIL");
        testReportAddWindowCapture("Trace", "", "");
      }
      ReadDataByPeriodicIdentifier();
      break;
      
    case 6:
      Send_Diag_Request(0x03, 0x2A, 0x05, 0x45, 0x00, 0x00, 0x00, 0x00);    
      testWaitForTimeout (900);
      testStep("", "11.5.4 Supported negative response codes (NRC_)");
      testStep("", "NRC - 31");
      
      if (SID_2A == 9)
      {
        testStepPass("PASS");
        testReportAddWindowCapture("Trace", "", "");
      }
      else
      {
        testStepFail("FAIL");
        testReportAddWindowCapture("Trace", "", "");
      }
      ReadDataByPeriodicIdentifier();
      break;
      
    case 7:
      Send_Diag_Request(0x03, 0x2A, 0x05, 0x46, 0x00, 0x00, 0x00, 0x00); 
      testWaitForTimeout (900);
      testStep("", "11.5.4 Supported negative response codes (NRC_)");
      testStep("", "NRC - 31");
      
      if (SID_2A == 9)
      {
        testStepPass("PASS");
        testReportAddWindowCapture("Trace", "", "");
      }
      else
      {
        testStepFail("FAIL");
        testReportAddWindowCapture("Trace", "", "");
      }
      ReadDataByPeriodicIdentifier();
      break;
      
    case 8:
      Send_Diag_Request(0x04, 0x2A, 0x01, 0x45, 0x00, 0x00, 0x00, 0x00); 
      testWaitForTimeout (900);
      testStep("", "11.5.4 Supported negative response codes (NRC_)");
      testStep("", "NRC - 13");
      
      if (SID_2A == 11)
      {
        testStepPass("PASS");
        testReportAddWindowCapture("Trace", "", "");
      }
      else
      {
        testStepFail("FAIL");
        testReportAddWindowCapture("Trace", "", "");
      }
      ReadDataByPeriodicIdentifier();
      break;
      
    case 9:
      Send_Diag_Request(0x03, 0x02, 0x01, 0x45, 0x00, 0x00, 0x00, 0x00);
      testWaitForTimeout (900);
      testStep("", "11.5.4 Supported negative response codes (NRC_)");
      testStep("", "NRC - 11");
      
      if (SID_2A == 10)
      {
        testStepPass("PASS");
        testReportAddWindowCapture("Trace", "", "");
      }
      else
      {
        testStepFail("FAIL");
        testReportAddWindowCapture("Trace", "", "");
      }
      ReadDataByPeriodicIdentifier();
      break;
      
   case 10:
      Send_Diag_Request(0x03, 0x2A, 0x01, 0x47, 0x00, 0x00, 0x00, 0x00); 
      testWaitForTimeout (900);
      testStep("", "11.5.4 Supported negative response codes (NRC_)");
      testStep("", "NRC - 31");
     
      if (SID_2A == 9)
      {
        testStepPass("PASS");
        testReportAddWindowCapture("Trace", "", "");
      }
      else
      {
        testStepFail("FAIL");
        testReportAddWindowCapture("Trace", "", "");
      }
      ReadDataByPeriodicIdentifier();
      break;
     
    case 11:
      Send_Diag_Request(2, 0x10, 0x01, IDLE, IDLE, IDLE, IDLE, IDLE); // Default session
      testWaitForTimeout (900);
      ReadDataByPeriodicIdentifier();
      break;

    default:
      session += 1;
      didIndex = 0;
      transmission_mode = 0;
      if ((session == 2) || (session == 3))
      {
        traceWindowClear("Trace");
      }
      READ_DATA_BY_PERIODIC_IDENTIFIER = 0;
      if (session == 4)
      {
        cancelTimer (Timer2A);
      }
      else
      {
        ReadDataByPeriodicIdentifier();
      }
      break;                   
  }
}

void InputOutputControlByIdentifier() // Need to work
{
  setTimer(Timer2F, 1000);
  INPUT_OUTPUT_CONTROL_BY_IDENTIFIER++;
    
  switch (INPUT_OUTPUT_CONTROL_BY_IDENTIFIER) 
  {
    case 1: 
      Send_Diag_Request(0x02, 0x10, session, 0x00, 0x00, 0x00, 0x00, 0x00);
      
       
      if (session == 1) 
      {
          INPUT_OUTPUT_CONTROL_BY_IDENTIFIER = 3; 
      }
      else if ((session == 2) || (session == 3 ))
      {
        INPUT_OUTPUT_CONTROL_BY_IDENTIFIER =1;
      }
      InputOutputControlByIdentifier(); 
      break;
      
    case 2: 
      if ((session == 2) || (session == 3 )) 
      {  
          Send_Diag_Request(2, 0x27, 0x01, 0x00, 0x00, 0x00, 0x00, 0x00);
          
          INPUT_OUTPUT_CONTROL_BY_IDENTIFIER = 2;
      }
      InputOutputControlByIdentifier();
      break;
      
    case 3: 
      Send_Diag_Request(5, 0x27, 0x02, 0x35, 0xA3, 0x6C, 0x00, 0x00);
      
      
      break;
      
    case 4:  
      if (didIndex < 12) 
      {
        Send_Diag_Request(0x03, 0x22, DID[didIndex][0], DID[didIndex][1], 0x00, 0x00, 0x00, 0x00);
       
        INPUT_OUTPUT_CONTROL_BY_IDENTIFIER = 4;  
      } 
      else 
      {
        didIndex = 0;
        INPUT_OUTPUT_CONTROL_BY_IDENTIFIER = 0;  
        if (session ==4 )
        {
          INPUT_OUTPUT_CONTROL_BY_IDENTIFIER =  5;
        }
      }
      InputOutputControlByIdentifier();
      break;  
      
    case 5:
      if (didIndex < 12) 
      {
        if (subfunction < 4) 
        { 
          Send_Diag_Request(0x05, 0x2F, DID[didIndex][0], DID[didIndex][1], subfunction, 0x00, 0x00, 0x00);
          subfunction++;  
        } 
        else 
        {
          subfunction = 0;  
          didIndex++;  
          INPUT_OUTPUT_CONTROL_BY_IDENTIFIER = 3; 
        }
      }
      if (session == 4)
      {
        INPUT_OUTPUT_CONTROL_BY_IDENTIFIER = 5;
      }
      InputOutputControlByIdentifier();
      break;
        
    case 6:
      Send_Diag_Request(0x05, 0x22, 0xF1, 0x8C, 0x00, 0x00, 0x00, 0x00);
     
      INPUT_OUTPUT_CONTROL_BY_IDENTIFIER = 6;
      InputOutputControlByIdentifier();
      break;
      
    case 7:
      Send_Diag_Request(0x03, 0x21, 0xF1, 0x8C, 0x00, 0x00, 0x00, 0x00);
      
      InputOutputControlByIdentifier();
      break;
      
    case 8:
      Send_Diag_Request(0x03, 0x21, 0xF1, 0x8A, 0x00, 0x00, 0x00, 0x00);
      if(session == 4)
      {
        cancelTimer(Timer2F);
      }
      InputOutputControlByIdentifier();
      break;
      
    default:
      session += 1;
      didIndex = 0;
      subfunction = 0;
      if ((session == 2) || (session == 3))
      {
        traceWindowClear("Trace");
      }
      INPUT_OUTPUT_CONTROL_BY_IDENTIFIER = 0;
      if (session == 4)
      {
        cancelTimer (Timer2F);
      }
      else
      {
        InputOutputControlByIdentifier();
      }
      break;
  }
}

/***********************************************************************************************************************
 *                                     C A N   E V E N T   H A N D L E R 
 ***********************************************************************************************************************/
/* UDS Response frame */
on message 0x7EF
{ 
  
  /* Tester Present */
  if ((this.byte(0) == 0x06) && (this.byte(1) == 0x50) && (this.byte(2) == 0x01)) 
  {
    SID_3E = 1;
  }
  else if ((this.byte(0) == 0x02) && (this.byte(1) == 0x7E) && (this.byte(3) == 0x00))
  {
    SID_3E = 2;
  }
  else if ((this.byte(0) == 0x03) && (this.byte(1) == 0x7F) && (this.byte(2) == 0x3E) && (this.byte(3) == 0x13)) 
  {
    SID_3E = 3;
  }
  else if ((this.byte(0) == 0x06) && (this.byte(1) == 0x50) && (this.byte(2) == 0x02)) 
  {
    SID_3E = 4;
  }
  else if ((this.byte(0) == 0x06) && (this.byte(1) == 0x50) && (this.byte(2) == 0x03)) 
  {
    SID_3E = 5;
  }
  else if ((this.byte(0) == 0x03) && (this.byte(1) == 0x7F) && (this.byte(2) == 0x3E) && (this.byte(3) == 0x12)) 
  {
    SID_3E = 6;
  }
  else
  {
    SID_3E = 0;
  }
  
  
  /* Clear Diagnostic Information */
  if ((this.byte(0) == 0x06) && (this.byte(1) == 0x50) && (this.byte(2) == 0x01) && (this.byte(3) == 0x00) && (this.byte(4) == 0x32) && (this.byte(5) == 0x13) && (this.byte(6) == 0x88) && (this.byte(7) == 0x00))
  {
    SID_14 = 1;
  }
  else if ((this.byte(0) == 0x06) && (this.byte(1) == 0x50) && (this.byte(2) == 0x02) && (this.byte(3) == 0x00) && (this.byte(4) == 0x32) && (this.byte(5) == 0x13) && (this.byte(6) == 0x88) && (this.byte(7) == 0x00))
  {
    SID_14 = 2;
  }
  else if ((this.byte(0) == 0x06) && (this.byte(1) == 0x50) && (this.byte(2) == 0x03) && (this.byte(3) == 0x00) && (this.byte(4) == 0x32) && (this.byte(5) == 0x13) && (this.byte(6) == 0x88) && (this.byte(7) == 0x00))
  {
    SID_14 = 3;
  }
  else if ((this.byte(0) == 0x01) && (this.byte(1) == 0x54) && (this.byte(2) == IDLE) && (this.byte(3) == IDLE) && (this.byte(4) == IDLE) && (this.byte(5) == IDLE) && (this.byte(6) == IDLE) && (this.byte(7) == IDLE))
  {
    SID_14 = 4;
  }
  else if ((this.byte(0) == 0x03) && (this.byte(1) == 0x7F) && (this.byte(2) == 0x14) && (this.byte(3) == 0x13) && (this.byte(4) == IDLE) && (this.byte(5) == IDLE) && (this.byte(6) == IDLE) && (this.byte(7) == IDLE))
  {
    SID_14 = 5;
  }
  else if ((this.byte(0) == 0x03) && (this.byte(1) == 0x7F) && (this.byte(2) == 0x41) && (this.byte(3) == 0x11) && (this.byte(4) == IDLE) && (this.byte(5) == IDLE) && (this.byte(6) == IDLE) && (this.byte(7) == IDLE))
  {
