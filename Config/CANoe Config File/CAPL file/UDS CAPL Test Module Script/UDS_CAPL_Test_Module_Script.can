      {
        testStepPass("PASS");
        testReportAddWindowCapture("Trace", "", "");
      }
      else
      {
        testStepFail("FAIL");
        testReportAddWindowCapture("Trace", "", "");
      }
      ReadMemoryByAddress(); 
      break;
      
    case 3:
      if ((session == 2) || (session == 3))
      { 
        Send_Diag_Request(2, 0x27, 01, IDLE, IDLE, IDLE, IDLE, IDLE); // 27 01
        READ_MEMORY_BY_ADDRESS = 3;
      }
      testWaitForTimeout (900);
      testStep("", "10.4.2.2 Request message SubFunction parameter $Level (LEV_) definition");
      testStep("", "27 01");
      
      if (SID_23 == 5)
      {
        testStepPass("PASS");
        testReportAddWindowCapture("Trace", "", "");
      }
      else
      {
        testStepFail("FAIL");
        testReportAddWindowCapture("Trace", "", "");
      }
      ReadMemoryByAddress(); 
      break;
      
    case 4:
      Send_Diag_Request(5, 0x27, 0x02, key_1, key_2, key_3, IDLE, IDLE);  // 27 02
      testWaitForTimeout (900);
      testStep("", "10.4.2.2 Request message SubFunction parameter $Level (LEV_) definition");
      testStep("", "27 02");
      
      if (SID_23 == 6)
      {
        testStepPass("PASS");
        testReportAddWindowCapture("Trace", "", "");
      }
      else
      {
        testStepFail("FAIL");
        testReportAddWindowCapture("Trace", "", "");
      }
      ReadMemoryByAddress(); 
      break;
      
    case 5:
      Send_Diag_Request(7, 0x23, addresslength, memoryaddress1, memoryaddress2, memoryaddress3, memoryaddress4, memorysize);  // 23
      testWaitForTimeout (900);
      testStep("", "11.3.2.1 Request message definition");
      
      if ((session == 1 ) && (SID_23 == 4))
      {
        testStep("", "NRC - 33");
      }
      else if (((session == 2) || (session == 3)) && (SID_23 == 7))
      {
        testStep("", "07 23");
      }
      
      if (((session == 1 ) && (SID_23 == 4)) || (((session == 2) || (session == 3)) && (SID_23 == 7)))
      {
        testStepPass("PASS");
        testReportAddWindowCapture("Trace", "", "");
      }
      else
      {
        testStepFail("FAIL");
        testReportAddWindowCapture("Trace", "", "");
      }
      ReadMemoryByAddress(); 
      break;
      
    case 6:
      Send_Diag_Request(4, 0x23, addresslength, memoryaddress1, memoryaddress2, memoryaddress3, memoryaddress4, memorysize);  // NRC 13
      testWaitForTimeout (900);
      testStep("", "11.3.4 Supported negative response codes (NRC_)");
      testStep("", "NRC - 13");
      
      if (((session == 1 ) && (SID_23 == 4)) || (((session == 2) || (session == 3)) && (SID_23 == 8)))
      {
        testStepPass("PASS");
        testReportAddWindowCapture("Trace", "", "");
      }
      else
      {
        testStepFail("FAIL");
        testReportAddWindowCapture("Trace", "", "");
      }
      ReadMemoryByAddress(); 
      break;
      
    case 7:
      Send_Diag_Request(7, 0x32, addresslength, memoryaddress1, memoryaddress2, memoryaddress3, memoryaddress4, memorysize);  // NRC 11
      testWaitForTimeout (900);
      testStep("", "11.3.4 Supported negative response codes (NRC_)");
      testStep("", "NRC - 11");
      
      if (SID_23 == 9)
      {
        testStepPass("PASS");
        testReportAddWindowCapture("Trace", "", "");
      }
      else
      {
        testStepFail("FAIL");
        testReportAddWindowCapture("Trace", "", "");
      }
      ReadMemoryByAddress(); 
      break;
      
    case 8:
      Send_Diag_Request(7, 0x23, 0x41, memoryaddress1, memoryaddress2, memoryaddress3, memoryaddress4, memorysize);  // NRC 31
      testWaitForTimeout (900);
      testStep("", "11.3.4 Supported negative response codes (NRC_)");
      testStep("", "NRC - 31");
      
      if (((session == 1 ) && (SID_23 == 4)) || (((session == 2) || (session == 3)) && (SID_23 == 10)))
      {
        testStepPass("PASS");
        testReportAddWindowCapture("Trace", "", "");
      }
      else
      {
        testStepFail("FAIL");
        testReportAddWindowCapture("Trace", "", "");
      }
      ReadMemoryByAddress(); 
      break;
      
    case 9:
      Send_Diag_Request(2, 0x10, 0x01, IDLE, IDLE, IDLE, IDLE, IDLE);  // Default session
      testWaitForTimeout (900);
      traceWindowClear("Trace");
      ReadMemoryByAddress(); 
      break;
        
    default:
      session += 1;
      if ((session == 2) || (session == 3))
      {
        traceWindowClear("Trace");
      }
      READ_MEMORY_BY_ADDRESS = 0;
      if (session == 4)
      {
        cancelTimer (Timer23);
        session = 1;
      }
      else 
      {
        ReadMemoryByAddress();  
      }
      break;
  }
} 

void SecurityAccess()
